/*
 * This file exists only so ZMK's shared-config lookup finds an exact match
 * for the "corne_trackball" shield and doesn't fall back to config/corne.keymap
 * (which is for the actual corne_left/corne_right keyboard halves and
 * references labels, like the corne physical layout's matrix transform,
 * that don't exist on this board).
 *
 * The real hardware/keymap content for this peripheral lives in
 * boards/shields/corne_trackball/corne_trackball.overlay.
 */
