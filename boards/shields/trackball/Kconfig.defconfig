if SHIELD_TRACKBALL

config ZMK_KEYBOARD_NAME
    default "Trackball"

config ZMK_SPLIT
    default y

config ZMK_SPLIT_ROLE_CENTRAL
    default n

# The split link to the dongle is BLE - this shield is useless without it.
# ZMK_BLE has no default of its own at zmk v0.3; it normally comes from
# ZMK's per-board conf (app/boards/seeeduino_xiao_ble.conf), but state it
# here too so a board-name change can't silently build a radio-less
# trackball again.
config ZMK_BLE
    default y

config ZMK_POINTING
    default y

# PMW3610 driver (badjeff/zmk-pmw3610-driver). It talks to the sensor over
# hardware SPI (the single SDIO line is wired to both MOSI and MISO), so
# SPI + pinctrl are required even though there's no dedicated SPI header used.
config PINCTRL
    default y

config SPI
    default y

config PMW3610_ALT
    default y

endif
